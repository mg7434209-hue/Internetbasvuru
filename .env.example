# Turhost PHP backend URL
BACKEND_API_URL=https://backend.internetbasvuru.com/lead.php

# API Secret Key (Turhost config.php ile aynı olmalı)
# Yeni key üretmek için: openssl rand -hex 32  (Linux/Mac)
# veya: -join ((1..32 | %{ '{0:x2}' -f (Get-Random -Max 256) }))  (PowerShell)
BACKEND_API_KEY=replace-with-your-own-64-char-hex-string

# Google Analytics 4 (opsiyonel)
NEXT_PUBLIC_GA_ID=

# Google Ads conversion (opsiyonel)
NEXT_PUBLIC_ADS_ID=
